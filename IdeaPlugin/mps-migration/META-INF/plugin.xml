<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>jetbrains.mps.ide.migration.idea</id>
  <name>MPS Migration Support for IDEA</name>
  <description>Adds support to migrate MPS models in MPS IDEA plugin</description>
  <version>2021.1.3</version>
  <vendor url="http://www.jetbrains.com/mps/">JetBrains</vendor>
  <idea-version since-build="211.1" until-build="212.1"/>

  <xi:include href="pluginBase.xml" xpointer="xpointer(/idea-plugin/*)"/>

  <extensions defaultExtensionNs="com.intellij">
    <postStartupActivity implementation="jetbrains.mps.migration.idea.PluginMigrationProblemHandler$Plug" />
  </extensions>
</idea-plugin>