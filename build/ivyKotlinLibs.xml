<ivy-module version="2.0"  xmlns:m="http://www.inversoft.com/schemas/savant-2.0/base">
  <info organisation="org.jetbrains.mps" module="idea-platform"/>
  <dependencies>
    <dependency org="org.jetbrains.kotlin" name="kotlin-stdlib-common" rev="${kotlin.version}">
      <artifact name="kotlin-stdlib-common" ext="jar"/>
      <artifact name="kotlin-stdlib-common" m:classifier="sources" ext="jar"/>
      <artifact name="kotlin-stdlib-common" m:classifier="javadoc" ext="jar"/>
    </dependency>
    <dependency org="org.jetbrains.kotlin" name="kotlin-compiler-embeddable" rev="${kotlin.version}">
      <artifact name="kotlin-compiler-embeddable" ext="jar"/>
      <artifact name="kotlin-compiler-embeddable" m:classifier="sources" ext="jar"/>
      <artifact name="kotlin-compiler-embeddable" m:classifier="javadoc" ext="jar"/>
    </dependency>
  </dependencies>
</ivy-module>