<project name="migrateSampleAndTestProjects" default="migrateAll" basedir="../">
  <property name="env.JAVA_HOME" value="${java.home}/.."/>
  <property name="jdk.home" value="${env.JAVA_HOME}"/>
  <!-- this has to be specified by caller -->
  <property name="mps_home" location="build/artifacts/mps"/>

  <!-- see mpsSmartRefAttrMigration.xml for additional details about migrate/@mpsHome -->
  <!-- The easiest way to use this script is to download MPS zip from Binaries, unzip and pass its location as mps_home -->

  <path id="path.mps.ant.path">
    <pathelement location="${mps_home}/lib/ant/lib/ant-mps.jar" />
    <fileset dir="${mps_home}/lib">
      <include name="util-8.jar" />
      <include name="3rd-party-rt.jar" />
    </fileset>
  </path>

  <taskdef resource="jetbrains/mps/build/ant/antlib.xml" classpathref="path.mps.ant.path"/>

  <target name="migrateAll" depends="migrateSampleProjects, migrateTestProjects">
    <echo message="Some projects were explicitly excluded, and need to be migrated manually (see sources of this script) "/>
  </target>

  <dirset id="samples" dir="${basedir}/samples">
    <present targetdir="${basedir}/samples">
      <globmapper from="*" to="*/.mps"/>
    </present>
    <!-- these projects require IDE and MPS project due to dependencies not available for migrate task -->
    <!-- Perhaps, can extend dependencies of migrate task with nested plugin or library? -->
    <!--
         FIXME figure out what's exactly prevents automatic migration, it's very tedious activity
            to update these once there's new migration. I didn't notice anything suspicious when did this recently.
         FWIW, in 24.3 these three has been migrated with the same script, and only messagesCustomization didn't migrate completely
          (didn't get specific migration mentioned in the file, but the version was bumped)
     -->
    <exclude name="generator_demo" />
    <exclude name="messagesCustomization" />
    <exclude name="customizedDebugger" />
  </dirset>

  <dirset id="testbench-modules" dir="${basedir}/testbench/modules">
    <present targetdir="${basedir}/testbench/modules">
      <globmapper from="*" to="*/.mps"/>
    </present>
    <!--
    alternatively:
    includes="testBehavior,simpleProject,testCloneModule,testCompilation,testRefactoring,build.mps.runner.test,build.mps.runner.test/project,testRefactoringWithMigration/MoveConcept_MPS_27372,testCompilationJavaXmlConflict"
    -->
    <exclude name="testCompilation" />
  </dirset>

  <dirset id="testbench-projects" dir="${basedir}/testbench/projects">
    <present targetdir="${basedir}/testbench/projects">
      <globmapper from="*" to="*/.mps"/>
    </present>
  </dirset>


  <target name="migrateSampleProjects">
    <migrate mpsHome="${mps_home}" makeDistribModules="false" autoPluginDiscovery="true">
      <dirset refid="samples"/>
      <jvmargs>
        <arg value="-Xmx1200m" />
        <arg value="-ea" />
      </jvmargs>
    </migrate>
  </target>

  <target name="migrateTestProjects">
    <migrate mpsHome="${mps_home}" makeDistribModules="false" autoPluginDiscovery="true">
      <project path="${basedir}/languages/languageDesign/generator/project.xmodel.test1"/>
      <project path="${basedir}/testbench/testsolutions/closures.test"/>
      <project path="${basedir}/testbench/modules/build.mps.runner.test/project"/>
      <project path="${basedir}/testbench/modules/testRefactoringWithMigration/MoveConcept_MPS_27372"/>
      <dirset refid="testbench-modules"/>
      <dirset refid="testbench-projects"/>
      <jvmargs>
        <arg value="-Xmx1200m" />
        <arg value="-ea" />
      </jvmargs>
    </migrate>
  </target>

</project>
