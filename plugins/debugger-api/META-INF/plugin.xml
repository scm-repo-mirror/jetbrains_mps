<!DOCTYPE idea-plugin PUBLIC "Plugin/DTD" "http://plugins.intellij.net/plugin.dtd">
<idea-plugin>
  <id>jetbrains.mps.debugger.api</id>
  <name>Debugger API for MPS</name>
  <description>Provides generic debugger support for MPS</description>
  <vendor url="http://www.jetbrains.com/mps/">JetBrains</vendor>

  <depends>jetbrains.mps.execution.api</depends>
  <depends>jetbrains.mps.core</depends>
  <depends>com.intellij.modules.mps</depends>

  <actions>
    <!--for being able to use StopAction in j.m.debug.api-->
    <group id="DebugStopAction" popup="false">
      <reference ref="Stop"/>
    </group>

    <!--for being able to use MuteAction in j.m.ide.actions-->
    <group id="DebugMuteAction" popup="false">
      <action id="Mute" text="Mute" class="jetbrains.mps.debugger.api.ui.actions.MuteBreakpoints"/>
    </group>
  </actions>

  <extensionPoints>
    <extensionPoint qualifiedName="jetbrains.mps.debugger.PositionProvider" beanClass="jetbrains.mps.debug.api.source.PositionProviderBean" dynamic="true">
      <with attribute="class" implements="jetbrains.mps.debug.api.source.IPositionProvider"/>
    </extensionPoint>
    <extensionPoint qualifiedName="jetbrains.mps.debugger.breakpointProvider" beanClass="jetbrains.mps.debug.api.breakpoints.BreakpointProviderBean" dynamic="false">
      <with attribute="class" implements="jetbrains.mps.debug.api.breakpoints.IBreakpointsProvider"/>
      <with attribute="id"/>
    </extensionPoint>
    <extensionPoint qualifiedName="jetbrains.mps.debugger.implementation" beanClass="jetbrains.mps.debug.api.DebuggerImplBean" dynamic="true">
      <with attribute="class" implements="jetbrains.mps.debug.api.IDebugger"/>
      <with attribute="id"/>
    </extensionPoint>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <projectService serviceImplementation="jetbrains.mps.debug.api.source.PositionProvider" />
    <programRunner id="defaultDebugRunner" implementation="jetbrains.mps.debugger.api.runner.MPSDebugRunner"
                   order="last"/>
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
    <mps.LanguageLibrary dir="/" hide="true"/>
    <mps.PluginComponentContributor application="jetbrains.mps.debugger.api.ui.actions.Runtime_ApplicationPlugin" />
    <applicationService serviceImplementation="jetbrains.mps.debug.api.BreakpointCreatorsManager"/>
    <applicationService serviceImplementation="jetbrains.mps.debug.api.breakpoints.BreakpointProvidersManager"/>
    <applicationService serviceImplementation="jetbrains.mps.debug.api.Debuggers"/>
    <projectService serviceImplementation="jetbrains.mps.debug.api.BreakpointManagerComponent"/>
    <projectService serviceImplementation="jetbrains.mps.debug.api.DebugSessionManagerComponent"/>
    <projectService serviceImplementation="jetbrains.mps.debugger.api.ui.breakpoints.BreakpointViewSettingsComponent"/>
    <!-- BreakpointEditorIntegration service comes together with EditorIntegrationListener projectListener, below -->
    <projectService serviceInterface="jetbrains.mps.debugger.core.breakpoints.BreakpointEditorIntegration"
                    serviceImplementation="jetbrains.mps.debugger.api.ui.breakpoints.BreakpointsUiComponent"/>
    <!-- CurrentLinePositionComponent and InTextPositionComponent rely on respective listeners, below -->
    <projectService serviceImplementation="jetbrains.mps.debugger.api.ui.executionPoint.CurrentLinePositionComponent"/>
    <projectService serviceImplementation="jetbrains.mps.debugger.api.ui.executionPoint.InTextPositionComponent"/>
  </extensions>

  <projectListeners>
    <!-- this listener works together with BreakpointEditorIntegration service, above-->
    <listener class="jetbrains.mps.debugger.core.breakpoints.EditorIntegrationListener"
              topic="jetbrains.mps.nodeEditor.highlighter.EditorComponentCreateListener"
              activeInTestMode="false"
              activeInHeadlessMode="false"/>
    <!-- next listeners are responsible to activate respective project services -->
    <listener class="jetbrains.mps.debugger.api.ui.executionPoint.CurrentLinePositionComponent$DebugListener"
              topic="jetbrains.mps.debug.api.DebugSessionManagerComponent$DebugSessionListener"
              activeInTestMode="false"
              activeInHeadlessMode="false"/>
    <listener class="jetbrains.mps.debugger.api.ui.executionPoint.InTextPositionComponent$DebugListener"
              topic="jetbrains.mps.debug.api.DebugSessionManagerComponent$DebugSessionListener"
              activeInTestMode="false"
              activeInHeadlessMode="false"/>
    <listener class="jetbrains.mps.debugger.api.ui.executionPoint.InTextPositionComponent$FileEditorListener"
              topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"
              activeInTestMode="false"
              activeInHeadlessMode="false"/>
  </projectListeners>

  <extensions defaultExtensionNs="jetbrains.mps">
    <debugger.PositionProvider key="jetbrains.mps.debug.api.source.NodePositionProvider" class="jetbrains.mps.debug.api.source.NodePositionProvider"/>
    <debugger.PositionProvider key="jetbrains.mps.debug.api.source.TextPositionProvider" class="jetbrains.mps.debug.api.source.TextPositionProvider"/>
  </extensions>

</idea-plugin>
