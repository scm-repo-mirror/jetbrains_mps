<project name="mpsTrueBootstrap" default="build" basedir="..">
  <!-- Generated by MPS -->
  <property name="build.dir" location="build" />
  <property name="build.tmp" location="${build.dir}/tmp/mpsTrueBootstrap" />
  <property name="build.layout" location="${build.dir}/artifacts/mpsTrueBootstrap" />
  <property name="projectHome" location="${basedir}" />
  <property name="idea_home" location="" />
  <property name="artifacts.IDEA" location="${idea_home}" />
  <property name="environment" value="env" />
  <property name="env.JAVA_HOME" value="${java.home}/.." />
  <property name="jdk.home" value="${env.JAVA_HOME}" />
  
  <path id="path.java.library.annotations-lib">
    <fileset file="${artifacts.IDEA}/lib/annotations.jar" />
  </path>
  
  <path id="path.java.library.jdom-lib">
    <fileset file="${artifacts.IDEA}/lib/jdom.jar" />
  </path>
  
  <path id="path.java.library.idea-ant">
    <fileset dir="${artifacts.IDEA}/lib/ant/lib" includes="*.jar" />
  </path>
  
  <path id="path.java.library.log4j-lib">
    <fileset file="${artifacts.IDEA}/lib/log4j.jar" />
  </path>
  
  <target name="assemble" depends="classes">
    <mkdir dir="${build.layout}" />
    <jar destfile="${build.layout}/mps-annotations.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/mps-annotations" />
    </jar>
    <jar destfile="${build.layout}/mps-tuples.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/mps-tuples" />
    </jar>
    <jar destfile="${build.layout}/mps-closures.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/mps-closures" />
    </jar>
    <jar destfile="${build.layout}/mps-references.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/mps-references" />
    </jar>
    <jar destfile="${build.layout}/mps-collections.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/mps-collections" />
    </jar>
    <jar destfile="${build.layout}/ant-mps.jar" duplicate="preserve">
      <fileset dir="${build.tmp}/java/out/ant-mps" />
    </jar>
  </target>
  
  <target name="buildDependents" />
  
  <target name="fetchDependencies" />
  
  <target name="build" depends="assemble" />
  
  <target name="clean">
    <delete dir="${build.tmp}" />
    <delete dir="${build.layout}" />
  </target>
  
  <target name="compileJava" depends="java.compile.mps-annotations, java.compile.mps-tuples, java.compile.mps-closures, java.compile.mps-references, java.compile.mps-collections, java.compile.ant-mps" />
  
  <target name="processResources" />
  
  <target name="classes" depends="compileJava, processResources" />
  
  <target name="test" depends="classes" />
  
  <target name="check" depends="test" />
  
  <target name="java.compile.mps-annotations">
    <mkdir dir="${projectHome}/core/mps-annotations/source" />
    <mkdir dir="${build.tmp}/java/out/mps-annotations" />
    <javac destdir="${build.tmp}/java/out/mps-annotations" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/core/mps-annotations/source" />
      </src>
      <classpath refid="path.java.library.annotations-lib" />
    </javac>
  </target>
  
  <target name="java.compile.mps-tuples">
    <mkdir dir="${projectHome}/languages/baseLanguage/tuples/runtime/source_gen" />
    <mkdir dir="${build.tmp}/java/out/mps-tuples" />
    <javac destdir="${build.tmp}/java/out/mps-tuples" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/languages/baseLanguage/tuples/runtime/source_gen" />
      </src>
      <classpath />
    </javac>
  </target>
  
  <target name="java.compile.mps-closures">
    <mkdir dir="${projectHome}/languages/baseLanguage/closures/runtime/source_gen" />
    <mkdir dir="${build.tmp}/java/out/mps-closures" />
    <javac destdir="${build.tmp}/java/out/mps-closures" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/languages/baseLanguage/closures/runtime/source_gen" />
      </src>
      <classpath />
    </javac>
  </target>
  
  <target name="java.compile.mps-references">
    <mkdir dir="${projectHome}/languages/baseLanguage/references/runtime/source" />
    <mkdir dir="${build.tmp}/java/out/mps-references" />
    <javac destdir="${build.tmp}/java/out/mps-references" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/languages/baseLanguage/references/runtime/source" />
      </src>
      <classpath />
    </javac>
  </target>
  
  <target name="java.compile.mps-collections" depends="java.compile.mps-closures, java.compile.mps-references">
    <mkdir dir="${projectHome}/languages/baseLanguage/collections/runtime/source_gen" />
    <mkdir dir="${build.tmp}/java/out/mps-collections" />
    <javac destdir="${build.tmp}/java/out/mps-collections" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/languages/baseLanguage/collections/runtime/source_gen" />
      </src>
      <classpath>
        <pathelement path="${build.tmp}/java/out/mps-closures" />
        <pathelement path="${build.tmp}/java/out/mps-references" />
      </classpath>
    </javac>
  </target>
  
  <target name="java.compile.ant-mps" depends="java.compile.mps-annotations">
    <mkdir dir="${projectHome}/core/tool/ant/source_gen" />
    <mkdir dir="${projectHome}/core/tool/common/source_gen" />
    <mkdir dir="${build.tmp}/java/out/ant-mps" />
    <javac destdir="${build.tmp}/java/out/ant-mps" fork="true" encoding="utf8" includeantruntime="false" debug="true">
      <compilerarg value="-Xlint:none" />
      <src>
        <path location="${projectHome}/core/tool/ant/source_gen" />
        <path location="${projectHome}/core/tool/common/source_gen" />
      </src>
      <classpath>
        <pathelement path="${build.tmp}/java/out/mps-annotations" />
        <path refid="path.java.library.annotations-lib" />
        <path refid="path.java.library.jdom-lib" />
        <path refid="path.java.library.log4j-lib" />
        <path refid="path.java.library.idea-ant" />
      </classpath>
    </javac>
    <copy todir="${build.tmp}/java/out/ant-mps">
      <fileset dir="${projectHome}/core/tool/ant/resources" />
    </copy>
  </target>
</project>