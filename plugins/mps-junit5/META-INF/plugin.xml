<!DOCTYPE idea-plugin PUBLIC 'Plugin/DTD' 'http://plugins.intellij.net/plugin.dtd'>
<idea-plugin>
  <id>jetbrains.mps.junit5</id>
  <name>MPS JUnit5 support</name>
  <category>Custom Languages</category>
  <description>JUnit5 libraries and stub models for use in MPS tests</description>
  <version>2024.3.6</version>
  <vendor url="http://www.jetbrains.com/mps/">JetBrains</vendor>
  <idea-version since-build="243.1" until-build="251.1"/>

  <depends>jetbrains.mps.core</depends>

  <extensions defaultExtensionNs="com.intellij">
    <mps.LanguageLibrary dir="/" hide="true"/>
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
  </extensions>
</idea-plugin>
