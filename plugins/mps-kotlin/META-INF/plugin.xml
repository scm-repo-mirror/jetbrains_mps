<!DOCTYPE idea-plugin PUBLIC 'Plugin/DTD' 'http://plugins.intellij.net/plugin.dtd'>
<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>jetbrains.mps.kotlin</id>
  <name>Kotlin MPS</name>
  <description>Kotlin languages for MPS and interoperability with baseLanguage</description>
  <vendor url="http://www.jetbrains.com/mps/">JetBrains</vendor>

  <depends>jetbrains.mps.core</depends>
  <depends>com.intellij.modules.mps</depends>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Integrated in mps-core for now (see MPSPersistence) -->
    <!--<mps.modelRootFactory rootType="kotlin_common" className="jetbrains.mps.kotlin.ide.commonStubs.KotlinCommonStubModelRootFactory"/>-->
    <!--<mps.modelIdFactory type="kotlin" className="jetbrains.mps.kotlin.ide.common.KotlinPackageModelId$Factory"/>-->

    <!-- UI entry for kotlin roots -->
    <mps.modelRootEntry rootType="kotlin_common" title="Kotlin"
                        className="jetbrains.mps.kotlin.idePlugin.rootEntry.KotlinStubModelRootEntryFactory"/>
    <mps.modelRootEntry rootType="kotlin_jvm" title="Kotlin JVM (deprecated)"
                        className="jetbrains.mps.kotlin.idePlugin.rootEntry.KotlinStubModelRootEntryFactory"/>

    <!-- Metadata file types + indexing facility -->
    <fileType extensions="kotlin_metadata;kotlin_builtins;knm" name="KOTLIN_METADATA" fieldName="INSTANCE"
              implementationClass="jetbrains.mps.kotlin.idePlugin.fileTypes.KotlinMetadataFileType"/>
    <idIndexer filetype="KOTLIN_METADATA" implementationClass="jetbrains.mps.kotlin.idePlugin.fastSearch.KotlinStubIdIndexer"/>
    <postStartupActivity implementation="jetbrains.mps.kotlin.idePlugin.KotlinPluginProjectActivity"/>

    <!-- Kotlin file type + highlighting facility -->
    <fileType extensions="kt" name="KOTLIN" fieldName="INSTANCE" language="KOTLIN" hashBangs="kotlin"
              implementationClass="jetbrains.mps.kotlin.idePlugin.fileTypes.KotlinFileType"/>
    <!-- TODO for MPS-34263: have an actual kotlin file highlighter -->
    <syntaxHighlighter key="KOTLIN" implementationClass="jetbrains.mps.ide.java.JavaFileHighlighter"/>

  </extensions>
  <extensions defaultExtensionNs="com.intellij">
    <mps.LanguageLibrary dir="/languages" hide="true"/>
    <mps.LanguageLibrary dir="/solutions" hide="true"/>
    <mps.LanguageLibrary dir="/devkits" hide="true"/>
  </extensions>
</idea-plugin>