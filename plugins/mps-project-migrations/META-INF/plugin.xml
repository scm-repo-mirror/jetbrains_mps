<!DOCTYPE idea-plugin
        PUBLIC
        "Plugin/DTD"
        "http://plugins.intellij.net/plugin.dtd"
        >
<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>jetbrains.mps.ide.mpsmigration</id>
  <name>Migration 2025.1</name>
  <description>Provides actions to migrate models and languages developed using previous versions of MPS</description>
  <version>2025.3.1</version>
  <vendor url="http://www.jetbrains.com/mps/" email="support@jetbrains.com">JetBrains</vendor>
  <idea-version since-build="253.1" until-build="261.1"/>
  <dependencies>
    <plugin id="jetbrains.mps.core"/>
  </dependencies>

  <depends>jetbrains.mps.ide.migration.workbench</depends>

  <extensions defaultExtensionNs="com.intellij">
    <mps.LanguageLibrary dir="/solution" hide="true"/>
    <mps.LanguageLibrary dir="/languages" hide="true"/>
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"></errorHandler>
  </extensions>
</idea-plugin>
