<!DOCTYPE idea-plugin
        PUBLIC
        "Plugin/DTD"
        "http://plugins.intellij.net/plugin.dtd"
        >
<idea-plugin>
  <id>jetbrains.mps.rcp</id>
  <name>MPS RCP Facilities</name>
  <description>Provides general actions and tools for MPS-based RCP application</description>
  <category>Custom Languages</category>
  <version>2024.3.6</version>
  <vendor url="http://www.jetbrains.com/mps/" email="support@jetbrains.com">JetBrains</vendor>
  <idea-version since-build="243.1" until-build="251.1"/>
  <depends>jetbrains.mps.core</depends>

  <extensions defaultExtensionNs="com.intellij">
    <mps.LanguageLibrary dir="/" hide="true"/>
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"></errorHandler>
  </extensions>
</idea-plugin>
