<!DOCTYPE idea-plugin PUBLIC "Plugin/DTD" "http://plugins.intellij.net/plugin.dtd">
<idea-plugin >
  <id>jetbrains.mps.editor.spellcheck</id>
  <name>Spell Check in MPS Editors</name>
  <description>Integrate IDEA spell-checking mechanism with MPS Editors</description>
  <version>2025.3.1</version>
  <vendor url="http://www.jetbrains.com/mps/" email="support@jetbrains.com">JetBrains</vendor>
  <idea-version since-build="253.1" until-build="261.1"/>
  <dependencies>
    <plugin id="jetbrains.mps.core"/>
    <module name="intellij.spellchecker"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <mps.LanguageLibrary dir="/" hide="true"/>
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
  </extensions>
</idea-plugin>
