<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>com.intellij</id>
  <name>IDEA CORE</name>

  <module value="com.intellij.modules.mps"/>
  <module value="com.intellij.modules.all"/>

  <xi:include href="/META-INF/IdeTipsAndTricks.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/PlatformLangPlugin.xml" xpointer="xpointer(/idea-plugin/*)"/>

  <!-- Next three includes can be removed if PlatformLangXmlPlugin.xml will be imported instead of PlatformLangPlugin.xml -->
  <xi:include href="/META-INF/XmlPlugin.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/JsonPlugin.xml" xpointer="xpointer(/idea-plugin/*)">
    <xi:fallback/>
  </xi:include>
  <xi:include href="/META-INF/SpellCheckerPlugin.xml" xpointer="xpointer(/idea-plugin/*)">
    <xi:fallback/>
  </xi:include>

  <!-- Customizations to platform -->
  <actions>
    <!-- File -->
    <action id="NewElement" class="com.intellij.ide.actions.NewElementAction"/>
    <group id="OpenProjectGroup">
      <group id="NewElementInMenuGroup" class="com.intellij.ide.actions.NewActionGroup" text="New" popup="true"/>
      <add-to-group group-id="FileOpenGroup" anchor="first"/>
    </group>
    <group id="MPSNewProjectOrModuleGroup">
      <action id="NewProject" class="jetbrains.mps.workbench.actions.NewMPSProjectAction" text="New MPS Project"/>
      <add-to-group group-id="NewProjectOrModuleGroup"/>
    </group>
    <action id="ForceSaveAll" class="jetbrains.mps.ide.actions.ForcedSaveAll_Action">
      <add-to-group group-id="FileMenu" relative-to-action="SaveAll" anchor="after"/>
    </action>
    <action id="SaveAsNewFormat" class="com.intellij.ide.actions.SaveAsDirectoryBasedFormatAction" text="Save as Directory-Based Format...">
      <add-to-group group-id="ExportImportGroup" anchor="last"/>
    </action>

    <!--Start of analog of groups changes from JavaActions.xml-->
    <!-- Analyze -->
    <group overrides="true" class="com.intellij.openapi.actionSystem.EmptyActionGroup" id="AnalyzePlatformMenu"/>
    <group overrides="true" class="com.intellij.openapi.actionSystem.EmptyActionGroup" id="InspectCodeInCodeMenuGroup"/>
    <group overrides="true" class="com.intellij.openapi.actionSystem.EmptyActionGroup" id="InspectCodeActionInPopupMenus"/>

    <group id="AnalyzeActions">
    </group>

    <group id="AnalyzeMenu" popup="true">
      <separator/>
      <reference ref="AnalyzeActions"/>
      <add-to-group group-id="MainMenu" anchor="after" relative-to-action="CodeMenu"/>
    </group>

    <!-- Help -->
    <action id="WhatsNewAction" class="com.intellij.ide.actions.WhatsNewAction">
      <add-to-group group-id="HelpMenu" anchor="after" relative-to-action="ShowTips"/>
    </action>
    <!--End of analog of groups changes from JavaActions.xml-->
  </actions>

  <xi:include href="/META-INF/MPSComponents.xml" xpointer="xpointer(/components/*)"/> <!--only MPS components-->
  <xi:include href="/idea/MPSActionManager.xml" xpointer="xpointer(/component/*)"/> <!--only MPS actions-->
  <xi:include href="/jetbrains/mps/ide/platform/actions/PlatformActions.xml" xpointer="xpointer(/components/*)"/> <!--only MPS actions-->
  <xi:include href="/jetbrains/mps/ide/editor/actions/MPSEditorActions.xml" xpointer="xpointer(/components/*)"/> <!--only MPS editor actions-->

  <extensions defaultExtensionNs="com.intellij">
    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
    <!-- The only reason this contribution is here is that it replaces Ide_PluginInitializer app component that used to be registered here -->
    <mps.PluginComponentContributor application="jetbrains.mps.ide.actions.Ide_ApplicationPlugin" project="jetbrains.mps.ide.actions.Ide_ProjectPlugin" />
  </extensions>

  <extensionPoints>
    <extensionPoint name="mps.CodeNavigationProvider" interface="jetbrains.mps.ide.navigation.CodeNavigationProvider"/>
    <extensionPoint name="mps.ModelValidator" interface="jetbrains.mps.ide.generator.ModelValidator"/>
    <extensionPoint name="mps.TabColorProvider" area="IDEA_PROJECT" interface="jetbrains.mps.ide.editorTabs.TabColorProvider"/>
    <extensionPoint name="mps.projectPrefsPanel" interface="jetbrains.mps.workbench.dialogs.project.properties.project.ProjectPrefsExtraPanel"
                    area="IDEA_PROJECT"/>
    <extensionPoint name="mps.projectGroupTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.ProjectTemplatesGroup"/>
    <extensionPoint name="mps.languageProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.LanguageProjectTemplate"/>
    <extensionPoint name="mps.solutionProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.SolutionProjectTemplate"/>
    <extensionPoint name="mps.otherProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.OtherProjectTemplate"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationInitializedListener implementation="com.intellij.internal.statistic.updater.StatisticsJobsScheduler"/>

    <projectViewPane implementation="jetbrains.mps.ide.projectPane.ProjectPane"/>
    <projectViewPane implementation="jetbrains.mps.ide.projectPane.fileSystem.FileViewProjectPane"/>

    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
    <analyzeStacktraceFilter implementation="jetbrains.mps.ide.actions.StandaloneMPSStackTraceFilter"/>

    <directoryIndexExcludePolicy implementation="jetbrains.mps.ide.vfs.ClassesGenPolicy"/>

    <applicationService serviceInterface="com.intellij.codeInsight.daemon.DaemonCodeAnalyzerSettings"
                        serviceImplementation="jetbrains.mps.codeInsight.daemon.MockDaemonCodeAnalyzerSettingsImpl"
                        overrides="true"/>
    <!-- MPS Patch-->
    <applicationService serviceInterface="com.intellij.ui.EditorTextFieldProvider"
                        serviceImplementation="jetbrains.mps.EditorTextFieldProviderImpl"
                        overrides="true"/>
    <!-- MPS patch: allows show custom info when no editors opened-->
    <applicationService serviceInterface="com.intellij.openapi.fileEditor.impl.EditorEmptyTextPainter"
                        serviceImplementation="jetbrains.mps.ide.ui.fileEditor.MPSEditorEmptyTextPainter"
                        overrides="true"/>

    <!-- Same as in community/java/ide-customization/resources/META-INF/plugin.xml -->
    <!-- preload because in any case will be requested to reopen last projects -->
    <applicationService serviceInterface="com.intellij.ide.RecentProjectsManager"
                        serviceImplementation="com.intellij.ide.RecentProjectsManagerBase"
                        overrides="true" preload="notHeadless"/>

    <!-- Start of same registrations as in JavaPlugin.xml TODO: check applicability in MPS -->
    <applicationService serviceInterface="com.intellij.openapi.projectRoots.ProjectJdkTable"
                        serviceImplementation="com.intellij.openapi.projectRoots.impl.JavaAwareProjectJdkTableImpl"
                        overrides="true"/>

    <applicationService serviceInterface="com.intellij.execution.runners.ProcessProxyFactory"
                        serviceImplementation="com.intellij.execution.runners.ProcessProxyFactoryImpl"/>

    <applicationService serviceImplementation="com.intellij.debugger.settings.NodeRendererSettings"/>
    <applicationService serviceImplementation="com.intellij.debugger.settings.ViewsGeneralSettings"/>
    <applicationService serviceImplementation="com.intellij.debugger.settings.DebuggerSettings"/>
    <projectService serviceImplementation="com.intellij.debugger.settings.DebuggerProjectSettings"/>
    <applicationService serviceImplementation="com.intellij.debugger.settings.ThreadsViewSettings"/>
    <applicationService serviceImplementation="com.intellij.debugger.settings.TraceSettings"/>
    <projectService serviceInterface="com.intellij.debugger.ui.HotSwapUI" serviceImplementation="com.intellij.debugger.ui.HotSwapUIImpl"/>
    <projectService serviceInterface="com.intellij.debugger.DebuggerManager" serviceImplementation="com.intellij.debugger.impl.DebuggerManagerImpl"/>

    <statistics.counterUsagesCollector groupId="java.find.usages" version="1"/>
    <statistics.counterUsagesCollector groupId="java.extract.method" version="1"/>
    <statistics.applicationUsagesCollector implementation="com.intellij.debugger.settings.DebuggerSettingsStatisticsCollector"/>
    <statistics.applicationUsagesCollector implementation="com.intellij.refactoring.JavaRefactoringUsageCollector"/>

    <applicationService serviceInterface="com.intellij.packaging.elements.PackagingElementFactory"
                        serviceImplementation="com.intellij.packaging.impl.elements.PackagingElementFactoryImpl"/>

    <applicationService serviceInterface="com.intellij.openapi.roots.ui.OrderEntryAppearanceService"
                        serviceImplementation="com.intellij.openapi.roots.ui.OrderEntryAppearanceServiceImpl"/>

    <projectService serviceInterface="com.intellij.packaging.artifacts.ArtifactPointerManager"
                    serviceImplementation="com.intellij.packaging.impl.artifacts.ArtifactPointerManagerImpl"/>
    <projectService serviceInterface="com.intellij.packaging.impl.artifacts.ArtifactBySourceFileFinder"
                    serviceImplementation="com.intellij.packaging.impl.artifacts.ArtifactBySourceFileFinderImpl"/>
    <applicationService serviceImplementation="com.intellij.packaging.impl.artifacts.InvalidArtifactType"/>
    <!-- End of same registrations as in JavaPlugin.xml -->

    <!--Editor-->
    <editorOptionsProvider instance="jetbrains.mps.nodeEditor.EditorSettingsConfigurable$EditorSettingsConfigurableOptionsProvider"/>
    <!--Editor Hints-->
    <projectConfigurable groupId="editor" groupWeight="180" dynamic="true"
                         instance="jetbrains.mps.nodeEditor.hintsSettings.ConceptEditorHintConfigurable"
                         displayName="Editor hints" order="after preferences.sourceCode" nonDefaultProject="true"/>
    <!-- Global Code Style -->
    <projectConfigurable groupId="editor" groupWeight="170" dynamic="true" bundle="messages.IdeBundle" key="configurable.CodeStyle.display.name"
                         id="preferences.sourceCode2" instance="jetbrains.mps.ide.codeStyle.CodeStyleSettingsConfigurable" order="after colors"/>
    <projectConfigurable groupId="build" groupWeight="110" instance="jetbrains.mps.ide.compiler.CompilerSettingsConfigurable" order="after project"
                         displayName="Java Compiler" nonDefaultProject="true"/>
    <applicationConfigurable groupId="editor" key="intention.settings" bundle="messages.CodeInsightBundle"
                             instance="jetbrains.mps.intentions.IntentionSettingsConfigurable" id="preferences.intentionPowerPack2"/>

    <!--MPS patch: add two setting pages-->
    <projectConfigurable groupId="build" groupWeight="130" instance="jetbrains.mps.library.ProjectLibraryManagerConfigurable"
                         id="preferences.projectLibraryManager" nonDefaultProject="true"/>
    <applicationConfigurable groupId="build" groupWeight="120" instance="jetbrains.mps.library.LibraryManagerConfigurable"
                             id="preferences.libraryManager"/>

    <projectService serviceInterface="com.intellij.openapi.roots.FileIndexFacade"
                    serviceImplementation="com.intellij.mock.MockFileIndexFacade" overrides="true"/>

    <!-- Use default implementation instead of PsiCachedValuesFactory in CoreImpl.xml-->
    <projectService serviceInterface="com.intellij.util.CachedValuesFactory"
                    serviceImplementation="com.intellij.util.DefaultCachedValuesFactory" overrides="true"/>

    <!-- allow mps to open mpr projects from command line -->
    <projectOpenProcessor implementation="jetbrains.mps.ide.project.MpsProjectOpenProcessor"/>

    <moduleRendererFactory implementation="com.intellij.ide.util.PlatformModuleRendererFactory" order="last" id="platform"/>

    <!--For run config creation with action-->
    <getDataRule key="Location"
                 implementationClass="jetbrains.mps.workbench.dataExtraction.runConfig.LocationRule"/>

    <editorTabTitleProvider implementation="jetbrains.mps.ide.editor.tabs.EditorTabTitleProviderImpl"/>

    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteNodeProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteReferenceProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteModelProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteModuleProvider"/>
    <!-- TODO: decide, if it is needed
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoritePropertyProvider"/>
    -->

    <!-- Seems like we should set platform prefix different from IDEA/community so this scope will not be necessary anymore -->
    <customScopesProvider implementation="com.intellij.packageDependencies.TestScopeProvider"/>

    <fileBasedIndex implementation="jetbrains.mps.ide.generator.index.ModelDigestIndex"/>
    <fileBasedIndex implementation="jetbrains.mps.ide.generator.index.BinaryModelDigestIndex"/>
    <indexedRootsProvider implementation="jetbrains.mps.ide.findusages.caches.MPSIndexableSetContributor"/>

    <syntaxHighlighter key="JAVA" implementationClass="jetbrains.mps.ide.java.JavaFileHighlighter"/>
    <syntaxHighlighter key="XML" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Model" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Solution" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Language" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Devkit" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="MPS Project" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>

    <gotoFileContributor implementation="jetbrains.mps.MPSGoToFileContributor"/>

    <projectService serviceInterface="com.intellij.ide.projectView.ProjectView"
                    serviceImplementation="jetbrains.mps.ide.projectView.ProjectViewImpl"
                    overrides="true"/>

    <fileIconProvider implementation="jetbrains.mps.workbench.editors.MPSIconProvider"/>

    <bundledKeymap file="Visual Studio.xml"/>

    <!-- TODO: check if can be removed -->
    <projectService serviceImplementation="com.intellij.openapi.vcs.impl.ModuleVcsDetector" preload="notHeadless"/>

    <projectService serviceInterface="com.intellij.psi.search.PsiSearchHelper"
                    serviceImplementation="jetbrains.mps.EmptyPsiSearchHelper" overrides="true"/>
    <projectService serviceInterface="com.intellij.psi.search.PsiTodoSearchHelper"
                    serviceImplementation="jetbrains.mps.EmptyPsiTodoSearchHelper" overrides="true"/>
  </extensions>

  <actions>
    <!--MPS Patch to avoid collision with Duplicate Node action TODO: find way to avoid this!!!-->
    <action id="CompareTwoFiles" class="com.intellij.openapi.actionSystem.EmptyAction" overrides="true"/>
    <action id="CompareDirs" class="com.intellij.openapi.actionSystem.EmptyAction" overrides="true"/>
    <action id="$Cut" class="jetbrains.mps.workbench.actions.MPSCutAction" icon="AllIcons.Actions.MenuCut" overrides="true"/>
    <action id="$Copy" class="jetbrains.mps.workbench.actions.MPSCopyAction" icon="AllIcons.Actions.Copy" overrides="true"/>
    <action id="$Paste" class="jetbrains.mps.workbench.actions.MPSPasteAction" icon="AllIcons.Actions.MenuPaste" overrides="true"/>
    <group id="FileChooserToolbar.MPS">
      <action id="FileChooser.GotoMPSModule"
              class="jetbrains.mps.ide.ui.filechoosers.treefilechooser.GotoModuleDirectory"
              icon="/nodes/ideaModule.png"/>
      <add-to-group group-id="FileChooserToolbar" anchor="after" relative-to-action="FileChooser.GotoProject"/>
    </group>
  </actions>

</idea-plugin>
