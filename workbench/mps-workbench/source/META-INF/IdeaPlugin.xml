<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>com.intellij</id>
  <name>IDEA CORE</name>

  <module value="com.intellij.modules.mps"/>
  <module value="com.intellij.modules.all"/>

  <xi:include href="/META-INF/IdeTipsAndTricks.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/idea/MPSRichPlatformPlugin.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/MPSComponents.xml" xpointer="xpointer(/components/*)"/>
  <xi:include href="/idea/MPSActionManager.xml" xpointer="xpointer(/component/*)"/>
  <xi:include href="/jetbrains/mps/ide/platform/actions/PlatformActions.xml" xpointer="xpointer(/components/*)"/>
  <xi:include href="/jetbrains/mps/ide/editor/actions/MPSEditorActions.xml" xpointer="xpointer(/components/*)"/>

  <extensions defaultExtensionNs="com.intellij">
    <!-- The only reason this contribution is here is that it replaces Ide_PluginInitializer app component that used to be registered here -->
    <mps.PluginComponentContributor application="jetbrains.mps.ide.actions.Ide_ApplicationPlugin" project="jetbrains.mps.ide.actions.Ide_ProjectPlugin" />
  </extensions>

  <extensionPoints>
    <extensionPoint name="mps.CodeNavigationProvider" interface="jetbrains.mps.ide.navigation.CodeNavigationProvider"/>
    <extensionPoint name="mps.ModelValidator" interface="jetbrains.mps.ide.generator.ModelValidator"/>
    <extensionPoint name="mps.TabColorProvider" area="IDEA_PROJECT" interface="jetbrains.mps.ide.editorTabs.TabColorProvider"/>
    <extensionPoint name="mps.projectPrefsPanel" interface="jetbrains.mps.workbench.dialogs.project.properties.project.ProjectPrefsExtraPanel"
                    area="IDEA_PROJECT"/>
    <extensionPoint name="mps.projectGroupTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.ProjectTemplatesGroup"/>
    <extensionPoint name="mps.languageProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.LanguageProjectTemplate"/>
    <extensionPoint name="mps.solutionProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.SolutionProjectTemplate"/>
    <extensionPoint name="mps.otherProjectTemplateEP" interface="jetbrains.mps.workbench.dialogs.project.newproject.OtherProjectTemplate"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationInitializedListener implementation="com.intellij.internal.statistic.updater.StatisticsJobsScheduler"/>

    <projectViewPane implementation="jetbrains.mps.ide.projectPane.ProjectPane"/>
    <projectViewPane implementation="jetbrains.mps.ide.projectPane.fileSystem.FileViewProjectPane"/>

    <errorHandler implementation="jetbrains.mps.ide.blame.CharismaReporter"/>
    <analyzeStacktraceFilter implementation="jetbrains.mps.ide.actions.StandaloneMPSStackTraceFilter"/>

    <additionalLibraryRootsProvider implementation="jetbrains.mps.ide.vfs.ProjectAdditionalRoots" />
    <directoryIndexExcludePolicy implementation="jetbrains.mps.ide.vfs.ClassesGenPolicy"/>

    <projectService serviceInterface="com.intellij.ide.projectView.impl.nodes.ProjectViewDirectoryHelper"
                    serviceImplementation="com.intellij.ide.projectView.impl.nodes.ProjectViewDirectoryHelper"/>
    <!--<projectService serviceInterface="com.intellij.openapi.vcs.changes.patch.PatchBaseDirectoryDetec  tor"
                    serviceImplementation="jetbrains.mps.MPSPatchBaseDirectoryDetector"/>-->

    <projectService serviceInterface="com.intellij.openapi.roots.FileIndexFacade"
                    serviceImplementation="com.intellij.mock.MockFileIndexFacade" overrides="true"/>

    <projectService serviceInterface="com.intellij.platform.ProjectBaseDirectory"
                    serviceImplementation="com.intellij.platform.ProjectBaseDirectory"/>

    <!-- Use default implementation instead of PsiCachedValuesFactory in CoreImpl.xml-->
    <projectService serviceInterface="com.intellij.util.CachedValuesFactory"
                    serviceImplementation="com.intellij.util.DefaultCachedValuesFactory" overrides="true"/>

    <!-- allow mps to open mpr projects from command line -->
    <projectOpenProcessor implementation="jetbrains.mps.ide.project.MpsProjectOpenProcessor"/>

    <moduleRendererFactory implementation="com.intellij.ide.util.PlatformModuleRendererFactory" order="last" id="platform"/>

    <!--For run config creation with action-->
    <getDataRule key="Location"
                 implementationClass="jetbrains.mps.workbench.dataExtraction.runConfig.LocationRule"/>

    <editorTabTitleProvider implementation="jetbrains.mps.ide.editor.tabs.EditorTabTitleProviderImpl"/>

    <applicationService serviceInterface="com.intellij.profile.codeInspection.InspectionProfileManager"
                        serviceImplementation="com.intellij.codeInspection.ex.ApplicationInspectionProfileManager"/>

    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteNodeProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteReferenceProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteModelProvider"/>
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoriteModuleProvider"/>
    <!-- TODO: decide, if it is needed
    <favoriteNodeProvider implementation="jetbrains.mps.ide.projectPane.favorites.providers.MPSFavoritePropertyProvider"/>
    -->

    <!-- Seems like we should set platform prefix different from IDEA/community so this scope will not be necessary anymore -->
    <customScopesProvider implementation="com.intellij.packageDependencies.TestScopeProvider"/>

    <fileBasedIndex implementation="jetbrains.mps.ide.generator.index.ModelDigestIndex"/>
    <fileBasedIndex implementation="jetbrains.mps.ide.generator.index.BinaryModelDigestIndex"/>
    <indexedRootsProvider implementation="jetbrains.mps.ide.findusages.caches.MPSIndexableSetContributor"/>

    <syntaxHighlighter key="JAVA" implementationClass="jetbrains.mps.ide.java.JavaFileHighlighter"/>
    <syntaxHighlighter key="XML" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Model" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Solution" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Language" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="Devkit" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>
    <syntaxHighlighter key="MPS Project" implementationClass="com.intellij.ide.highlighter.XmlFileHighlighter"/>

    <gotoFileContributor implementation="jetbrains.mps.MPSGoToFileContributor"/>

    <projectService serviceInterface="com.intellij.ide.projectView.ProjectView"
                    serviceImplementation="jetbrains.mps.ide.projectView.ProjectViewImpl"
                    overrides="true"/>

    <fileIconProvider implementation="jetbrains.mps.workbench.editors.MPSIconProvider"/>

    <bundledKeymap file="Visual Studio.xml"/>

    <!-- TODO: check if can be removed -->
    <projectService serviceImplementation="com.intellij.openapi.vcs.impl.ModuleVcsDetector" preload="notHeadless"/>

    <projectService serviceInterface="com.intellij.psi.search.PsiSearchHelper"
                    serviceImplementation="jetbrains.mps.EmptyPsiSearchHelper" overrides="true"/>
    <projectService serviceInterface="com.intellij.psi.search.PsiTodoSearchHelper"
                    serviceImplementation="jetbrains.mps.EmptyPsiTodoSearchHelper" overrides="true"/>
  </extensions>

</idea-plugin>
