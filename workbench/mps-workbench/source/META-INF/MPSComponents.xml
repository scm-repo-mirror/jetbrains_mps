    </component>
    <component>
      <implementation-class>jetbrains.mps.smodel.ModelValidationSettings</implementation-class>
    </component>
    <component>
      <implementation-class>jetbrains.mps.ide.navigation.NavigationSupportImpl</implementation-class>
    </component>
    <component>
