<components>
  <extensions defaultExtensionNs="com.intellij">
    <mps.facetTabFactory facetType="ideaPlugin" className="jetbrains.mps.ide.project.facets.ui.IdeaPluginModuleFacetTabFactory"/>
    <projectService serviceImplementation="jetbrains.mps.ide.projectPane.TreeNodeSortService"/>
  </extensions>
  <application-components>
    <component>
      <implementation-class>jetbrains.mps.repository.RepositoryInitializingComponent</implementation-class>
    </component>

    <component>
      <interface-class>jetbrains.mps.make.IMakeService</interface-class>
      <implementation-class>jetbrains.mps.ide.make.WorkbenchMakeService</implementation-class>
    </component>

  </application-components>

  <applicationListeners>
    <listener class="jetbrains.mps.repository.FSNotificationsCleaner" topic="com.intellij.ide.AppLifecycleListener"/>
    <listener class="jetbrains.mps.ide.blame.IntelliJReporterReplacer" topic="com.intellij.ide.AppLifecycleListener"/>
  </applicationListeners>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="jetbrains.mps.repository.FSNotificationsImprover"/>
    <projectService serviceImplementation="jetbrains.mps.ide.make.MakeServiceConfiguration"/>
    <mps.projectPrefsPanel implementation="jetbrains.mps.ide.make.MakeSettingsPanel"/>
  </extensions>

</components>
