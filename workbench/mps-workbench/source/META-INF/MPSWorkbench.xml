<components>
  <extensions defaultExtensionNs="com.intellij">
    <mps.facetTabFactory facetType="ideaPlugin" className="jetbrains.mps.ide.project.facets.ui.IdeaPluginModuleFacetTabFactory"/>
    <projectService serviceImplementation="jetbrains.mps.ide.projectPane.TreeNodeSortService"/>
  </extensions>
  <application-components>
    <component>
      <implementation-class>jetbrains.mps.repository.FSNotificationsImprover</implementation-class>
    </component>
    <component>
      <implementation-class>jetbrains.mps.repository.RepositoryInitializingComponent</implementation-class>
    </component>

    <component>
      <interface-class>jetbrains.mps.make.IMakeService</interface-class>
      <implementation-class>jetbrains.mps.ide.make.WorkbenchMakeService</implementation-class>
    </component>

    <component>
      <implementation-class>jetbrains.mps.ide.actions.refactoring.MoveModelExtensionComponent</implementation-class>
    </component>
  </application-components>

  <extensions defaultExtensionNs="com.intellij">
    <projectService serviceInterface="jetbrains.mps.ide.make.MakeServiceConfiguration"
                  serviceImplementation="jetbrains.mps.ide.make.MakeServiceConfiguration"/>
  </extensions>

</components>
