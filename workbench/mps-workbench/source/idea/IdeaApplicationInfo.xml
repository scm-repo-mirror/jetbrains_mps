<component xmlns="http://jetbrains.org/intellij/schema/application-info"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://jetbrains.org/intellij/schema/application-info http://jetbrains.org/intellij/schema/ApplicationInfo.xsd">
  <!-- Do not set minor version other than just one digit (minor="2" even for some 2018.2.# version) and eap other then eap="true":
  it is used for AffectedVersionTest#testVersion, which expect only EAP minor version
  TODO: this looks like hack and does not in any way reflects real version set in jetbrains.mps.ide.build.mps-->
  <version major="2020" minor="1" eap="true" update-channel="MPS201EAP"/>
  <company name="JetBrains s.r.o." url="https://www.jetbrains.com/?fromIDE" copyrightStart="2009"/>
  <build number="MPS-201.SNAPSHOT" date="__BUILD_DATE__"/>
  <!--<install-over minbuild="" maxbuild="" version=""/>-->
  <logo url="/splash.png" textcolor="FFFFFF" progressColor="FFFFFF" progressX="117" progressY="280" progressHeight="3"/>
  <about url="/about.png" foreground="FFFFFF" copyrightForeground="FFFFFF"/><!--linkColor="9b5121" logoX="300" logoY="265" logoW="75" logoH="30"-->
  <icon size32="/MPS_32.png" size16="/MPS_16.png" size128="/MPS_128.png" ico="MPS.ico"/>
  <package code="__PACKAGE_CODE__"/>
  <names product="MPS" fullname="JetBrains MPS"/>

  <welcome-screen logo-url="/MPS_welcomeScreen.png"/>
  <!--
  <customize-ide-wizard provider="com.intellij.ide.customize.CustomizeIdeaWizardStepsProvider"/>
  -->

  <!--
  <editor background-url="/idea_logo_welcome.png"/>
  -->

  <plugins url="https://plugins.jetbrains.com/"/>
  <update-urls check="https://www.jetbrains.com/mps/update.xml"
               patches="https://www.jetbrains.com/mps/download/"/>

  <help webhelp-url="https://www.jetbrains.com/mps/webhelp/"/>
  <documentation url="https://www.jetbrains.com/mps/documentation"/>
  <support url="https://www.jetbrains.com/support/mps/index.html"/>
  <feedback url="https://www.jetbrains.com/feedback/feedback.jsp?product=mps"/>
  <whatsnew url="https://www.jetbrains.com/mps/whatsnew/index.html"/>
  <keymap win="https://www.jetbrains.com/help/mps/2020.1/default-keymap-reference.html"
          mac="https://www.jetbrains.com/help/mps/2020.1/default-keymap-reference.html"/>
  <jetbrains-tv url="https://www.youtube.com/user/JetBrainsTV/search?query=MPS"/>

  <!--<plugins-page category="VCS Integration" title="Select VCS Integration Plugins"/>-->
  <!--<plugins-page title="Select Other Plugins"/>-->

